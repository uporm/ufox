# ==============================================================================
# ufox-llm 环境变量配置样例
#
# 将此文件复制为 .env 并填入你实际的配置信息。
# 注意：.env 文件不应该被提交到版本控制系统中。
# ==============================================================================

# [必填] LLM 服务提供商
# 支持的值：openai, compatible, anthropic, doubao, qwen, gemini
UFOX_LLM_PROVIDER=openai

# [必填] 用于认证的 API Key
UFOX_LLM_API_KEY=sk-xxxxxx

# [必填] 使用的模型名称
# 例如：gpt-4o, claude-3-5-sonnet-20241022, qwen-plus 等
UFOX_LLM_MODEL=gpt-4o

# [可选] 自定义 API 接口地址
# 如果 provider 是 `compatible`（如 Ollama、DeepSeek、Moonshot 等），则必须填写该项
# 其他 provider 可填写该项来覆盖默认地址（例如使用代理网关）
# UFOX_LLM_BASE_URL=https://api.openai.com/v1

# [可选] 请求总超时时间（秒）
# UFOX_LLM_TIMEOUT_SECS=600

# [可选] 建立连接的超时时间（秒）
# UFOX_LLM_CONNECT_TIMEOUT_SECS=5

# [可选] 读取响应的超时时间（秒）
# UFOX_LLM_READ_TIMEOUT_SECS=60
